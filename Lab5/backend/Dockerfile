# Використовуємо легку версію Node.js
FROM node:22-alpine

# Створюємо робочу директорію всередині контейнера
WORKDIR /app

# Копіюємо конфігурацію і встановлюємо залежності
COPY package*.json ./
RUN npm install

# Копіюємо весь інший код сервера
COPY . .

# Відкриваємо порт
EXPOSE 3000

# Команда для запуску сервера
CMD ["node", "server.js"]